# Format and print one designation's result
proc print_result { desig result status verbose } {
    global mpec provID rejected other_dates
    global unprocessed neocp queued pending published notminor artificial itf deleted notfound
    global desig_obscount scout_mode

    if {$verbose} {
	puts "-----"
	puts $result
	puts [format "%7s unp=%d neocp=%d que=%d pend=%d pub=%d notminor=%d artif=%d itf=%d rej=%d del=%d notfound=%d" $desig $unprocessed $neocp $queued $pending $published $notminor $artificial $itf $rejected $deleted $notfound]

    } else {
	# Build observation type prefix (before designation)
	set prefix ""
	if {[info exists desig_obscount($desig,survey)]} {
	    set sc $desig_obscount($desig,survey)
	    set fc $desig_obscount($desig,followup)
	    if {$sc >= 1 && $fc >= 1}    { set prefix "s+f" }  elseif \
	       {$sc > 1}                 { set prefix "s+s" }  elseif \
	       {$fc > 1}                 { set prefix "f+f" }  elseif \
	       {$sc == 1}                { set prefix "svy" }  elseif \
	       {$fc == 1}                { set prefix "fup" }
	}

	if {$prefix ne ""} {
	    set outstr [format "%s %s %s" $prefix $desig $status]
	} else {
	    set outstr [format "%s %s" $desig $status]
	}

	# maybe add deleted / rejected? Are there tracklets that are entirely deleted?
	if {$rejected > 0} { set outstr [concat $outstr $rejected] }

	# maybe adjust MPEC alignment for various cases?
	if {$mpec != "NONE"} { set outstr [concat $outstr "in" $mpec] }

	# doesn't currently distinguish between provID and permID
	if {$provID != "NONE"} {
	    set plen [string length $provID]
	    set outstr [concat $outstr [format "as %s" $provID]]
	}

	# Note other observation dates if present
	if {[llength $other_dates] > 0} {
	    set outstr [concat $outstr [format "\[also %s\]" [join $other_dates ", "]]]
	}

	puts $outstr

	# Scout lookup for NEOCP objects
	# "all" = always show, "auto" = only show alerts, "none" = never
	if {$scout_mode ne "none" && $neocp} {
	    set scout_result [scout_query $desig]
	    set scout_level [lindex $scout_result 0]
	    set scout_text  [lindex $scout_result 1]
	    if {$scout_text ne ""} {
		if {$scout_mode eq "all" || $scout_level eq "alert"} {
		    puts $scout_text
		}
	    }
	}
    }
}

if {$batch_mode && !$mpcd && [llength $clargs] > 0} {
    # Batch mode: one API call for all designations
    set batch_results [wamo_batch $clargs $site]

    foreach desig $clargs {
	if {[dict exists $batch_results $desig]} {
	    set result [dict get $batch_results $desig]
	} else {
	    set result ""
	}

	set status [trackstat $desig $result]
	log_query $desig $site $utdate $result $status
	incr ndesigs
	print_result $desig $result $status $verbose
    }

} else {
    # Sequential mode: one API call per designation, streaming output
    if {! $quiet} { puts stderr [format "querying %d designations..." [llength $clargs]] }
    foreach desig $clargs {
	set result [wamo_query $desig $site]
	set status [trackstat $desig $result]
	log_query $desig $site $utdate $result $status
	incr ndesigs
	print_result $desig $result $status $verbose
    }
}

puts [format "\n  total = %s designations\n" $ndesigs]

