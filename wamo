# should capture time-obs and sort
if {!$founddir && $infil == "NONE"} {
    if {$mpcd} {
	set filelist "*.mpcd"
    } else {
	set filelist "*.neos"
    }

    # Auto-detect working directory:
    # 1. If CWD has the needed files, use it
    # 2. Otherwise try /data0/YYMmmDD (tonight's UT date for CSS timezone)
    # 3. Otherwise print usage
    set datadir [pwd]
    if {[llength [glob -nocomplain $filelist]] == 0} {
	set tonight [GetTonightDir]
	set trydir [file join "/data0" $tonight]
	if {[file isdirectory $trydir] && [llength [glob -nocomplain -directory $trydir $filelist]] > 0} {
	    set datadir $trydir
	    cd $datadir
	    if {! $quiet} { puts stderr [format "using %s" $datadir] }
	} else {
	    puts stderr [format "no %s files in current directory or %s" $filelist $trydir]
	    print_usage
	}
    }

    if {$mpcd} {
	if {! $quiet} { puts stderr "sampling targets from `*.mpcd' files in current directory" }
    } else {
	if {! $quiet} { puts stderr "reading targets from `*.neos' files in current directory" }
    }

    set sites { G96 E12 I52 V06 V00 703 G84 }
    set site "NONE"

    set cmdfmt {cat %s | grep -v %sx | sed -e "s/.\*\ I52//" -e "s/.\*\ 703//" -e "s/.\*\ G96//" -e "s/.\*\ V06//" -e "s/.\*\ V00//" -e "s/.\*\ E12//" -e "s/.\*\ G84//" | sort | uniq}

    set tmplist {}

    set workdir [file tail [pwd]]
    set utdate [GetMPCDate $workdir]

    # Track observation type per designation: survey (N/S) vs followup (F/U)
    # desig_obscount(DESIG,survey) and desig_obscount(DESIG,followup) hold counts
    global desig_obscount

    # loop over neos (or mpcd) files
    foreach neos [ glob -nocomplain $filelist ] {
	# maybe wants to be first file in list?
	if {! $gotsite} {
	    set tmpsite [string range $neos 0 2]
	    if {[lsearch $sites $tmpsite] >= 0} {
		set site $tmpsite;
		incr gotsite
	    } else {
		# try reading the file, should do this in TCL
		set cmd [format "cat %s | head -1" $neos]
		catch { RunCommand $cmd } result

		set tmpsite [string range $result 77 79]
		if {[lsearch $sites $tmpsite] >= 0} { set site $tmpsite; incr gotsite }
	    }
	}

	# Extract field prefix from filename: TEL_DATE_BIN_Xnnnnn_REP_SEQ.ext
	# The 4th underscore-delimited component's first char is N/S/F/U
	set fname_parts [split [file tail $neos] "_"]
	if {[llength $fname_parts] >= 4} {
	    set field_prefix [string index [lindex $fname_parts 3] 0]
	} else {
	    set field_prefix ""
	}
	if {$field_prefix eq "F" || $field_prefix eq "U"} {
	    set this_type "followup"
	} else {
	    set this_type "survey"
	}

	catch { RunCommand [format $cmdfmt $neos $site] } result
	set result2 [string map -nocase {{*} { }} [join $result]]

	# 2 blanks, 7 char ID, asterisk
	# if {[string length $result] <= 9 || [string range $result 8 8] == "\ "}

	# handling for short IDs (5 or 6 characters)
	if {[string range $result 9 9] == "\ " || [string range $result 8 8] == "\ " || [string range $result 7 7] == "\ " || [string range $result 6 6] == "\ "} {
	    puts [format "  unreported observations in %s" $neos]
	}

        # support for 2 and 3 NEOs per neos file
        # perhaps rewrite the entire neos parsing
	# lappend tmplist [string range $result 2 8]
        # if {[string length $result] == 21} { lappend tmplist [string range $result 13 19] }
        # if {[string length $result] == 32} { lappend tmplist [string range $result 24 30] }

	# Record obstype counts for each designation found in this file
	foreach d [split $result2] {
	    set d [string trim $d]
	    if {$d eq ""} { continue }
	    if {![info exists desig_obscount($d,survey)]} {
		set desig_obscount($d,survey) 0
		set desig_obscount($d,followup) 0
	    }
	    if {$this_type eq "survey"} {
		incr desig_obscount($d,survey)
	    } else {
		incr desig_obscount($d,followup)
	    }
	}

	lappend tmplist [join $result2]
    }

    set tmplist2 [string map -nocase {{\{} { } {\}} { }} [split $tmplist]]

    if {$mpcd} {
	# Deduplicate, then sample up to 10 at random
	set unique_desigs [lsort -dictionary -unique $tmplist2]
	set nuniq [llength $unique_desigs]
	set nsample [expr {min(10, $nuniq)}]
	if {! $quiet} { puts stderr [format "sampling %d of %d unique designations" $nsample $nuniq] }

	if {$nsample == $nuniq} {
	    set clargs $unique_desigs
	} else {
	    # Fisher-Yates partial shuffle to pick nsample without replacement
	    set pool $unique_desigs
	    set clargs {}
	    for {set idx 0} {$idx < $nsample} {incr idx} {
		set remaining [expr {$nuniq - $idx}]
		set nn [expr {int(rand() * $remaining)}]
		lappend clargs [lindex $pool $nn]
		# Swap picked element to the end
		set pool [lreplace $pool $nn $nn [lindex $pool [expr {$remaining - 1}]]]
	    }
	    set clargs [lsort -dictionary $clargs]
	}
    } else {
	# Deduplicate: each designation queried once, sorted
	set clargs [lsort -dictionary -unique $tmplist2]
    }
}

